From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Mark Brand <mabrand@mabrand.nl>
Date: Wed, 6 May 2026 10:32:24 +0200
Subject: [PATCH 4/5] remove :: prefix


diff --git a/src/execdir.c b/src/execdir.c
index 1111111..2222222 100644
--- a/src/execdir.c
+++ b/src/execdir.c
@@ -40,7 +40,7 @@ size_t wchartoutf8(const wchar_t *in, size_t wlen, char *out, size_t outlen)
     }
     /* WideCharToMultiByte with 0 output buffer and length to get the actual needed length */
     flags = WC_ERR_INVALID_CHARS;
-    bytes = ::WideCharToMultiByte(CP_UTF8, flags, in, wlen, nullptr, 0, nullptr, nullptr);
+    bytes = WideCharToMultiByte(CP_UTF8, flags, in, wlen, nullptr, 0, nullptr, nullptr);
     if (bytes <= 0) {
         fwprintf(stderr, L"wchartoutf8: conversion error1 for [%s]\n", in);
         return 0;
@@ -54,7 +54,7 @@ size_t wchartoutf8(const wchar_t *in, size_t wlen, char *out, size_t outlen)
     }
 
     /* Perform the conversion */
-    bytes = ::WideCharToMultiByte(CP_UTF8, flags, in, wlen, out, outlen, nullptr, nullptr);
+    bytes = WideCharToMultiByte(CP_UTF8, flags, in, wlen, out, outlen, nullptr, nullptr);
     if (bytes <= 0) {
         fprintf(stderr, "wchartoutf8: WideCharToMultiByte (actual) failed\n");
         return 0;

From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Mark Brand <mabrand@mabrand.nl>
Date: Wed, 6 May 2026 10:56:04 +0200
Subject: [PATCH 5/5] skip execdir_setargv0() under windows

The comments in execdir.h say this is only for unix.

diff --git a/src/main.c b/src/main.c
index 1111111..2222222 100644
--- a/src/main.c
+++ b/src/main.c
@@ -149,7 +149,9 @@ main(int argc, char **argv)
 
 	int i;
 	nopict_mode = debug_mode = dump_mode = inline_mode = no_remap_mode = quiet = FALSE;
+#ifndef _WIN32
 	execdir_setargv0(argv[0]);
+#endif
 	/* initialize search path to compiled-in value */
 	search_path = DEFAULT_UNRTF_SEARCH_PATH;
 

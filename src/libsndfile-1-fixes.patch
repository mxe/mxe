From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Marco Borrini <borrinimarco74@gmail.com>
Date: Tue, 26 May 2026 13:25:00 +0200
Subject: [PATCH 1/1] Fix bool enum for C23 compatibility

In C23, bool, true, and false are native keywords. This patch wraps
the legacy ALAC enum definition to prevent compilation errors when
building with modern GCC (e.g., GCC 15/16).

diff --git a/src/ALAC/alac_decoder.c b/src/ALAC/alac_decoder.c
index 1111111..2222222 100644
--- a/src/ALAC/alac_decoder.c
+++ b/src/ALAC/alac_decoder.c
@@ -38,10 +38,16 @@
 #include "ALACBitUtilities.h"
 #include "EndianPortable.h"
 
+#ifndef __cplusplus
+#if __STDC_VERSION__ >= 199901L
+#include <stdbool.h>
+#else
 typedef enum
 {	false = 0,
 	true = 1
 } bool ;
+#endif
+#endif
 
 // constants/data
 const uint32_t kMaxBitDepth = 32 ;			// max allowed bit depth is 32
diff --git a/src/ALAC/alac_encoder.c b/src/ALAC/alac_encoder.c
index 3333333..4444444 100644
--- a/src/ALAC/alac_encoder.c
+++ b/src/ALAC/alac_encoder.c
@@ -44,11 +44,16 @@
 #include "ALACAudioTypes.h"
 #include "EndianPortable.h"
 
+#ifndef __cplusplus
+#if __STDC_VERSION__ >= 199901L
+#include <stdbool.h>
+#else
 typedef enum
-{
-	false = 0,
+{	false = 0,
 	true = 1
 } bool ;
+#endif
+#endif
 
 static void	GetConfig (ALAC_ENCODER *p, ALACSpecificConfig * config) ;
 

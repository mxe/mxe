diff --git a/lib/jxl.cmake b/lib/jxl.cmake
index 59b2cca4..8ffd74e0 100644
--- a/lib/jxl.cmake
+++ b/lib/jxl.cmake
@@ -27,9 +27,14 @@ if (JPEGXL_ENABLE_TRANSCODE_JPEG OR JPEGXL_ENABLE_BOXES)
 list(APPEND JPEGXL_DEC_INTERNAL_LIBS brotlidec brotlicommon)
 endif()

+# Patch lib/jxl.cmake:
+# Add brotlicommon to JPEGXL_INTERNAL_LIBS because static linking in MXE
+# does not automatically pull transitive Brotli dependencies. Without this,
+# linking fails with undefined Brotli symbols.
 set(JPEGXL_INTERNAL_LIBS
   ${JPEGXL_DEC_INTERNAL_LIBS}
   brotlienc
+  brotlicommon
 )

 if (JPEGXL_ENABLE_TRANSCODE_JPEG)
diff --git a/lib/jxl/libjxl.pc.in b/lib/jxl/libjxl.pc.in
index f5a9c436..ea02c496 100644
--- a/lib/jxl/libjxl.pc.in
+++ b/lib/jxl/libjxl.pc.in
@@ -7,7 +7,7 @@ Name: libjxl
 Description: Loads and saves JPEG XL files
 Version: @JPEGXL_LIBRARY_VERSION@
 @JPEGXL_REQUIRES_TYPE@: @JPEGXL_LIBRARY_REQUIRES@
-Libs: -L${libdir} -ljxl @JPEGXL_PUBLIC_LIBS@
+Libs: -L${libdir} -ljxl -ljxl_threads @JPEGXL_PUBLIC_LIBS@
 Libs.private: @JPEGXL_PRIVATE_LIBS@
 Cflags: -I${includedir}
 Cflags.private: -DJXL_STATIC_DEFINE

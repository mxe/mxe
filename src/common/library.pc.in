prefix=@PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: @NAME@
Description: @DESCRIPTION@
Version: @VERSION@

Requires: @REQUIRES@
Requires.private: @REQUIRES_PRIVATE@

Libs: -L${libdir} @LIBS@
Libs.private: @LIBS_PRIVATE@

Cflags: -I${includedir} @CFLAGS@
Cflags.private: @CFLAGS_PRIVATE@

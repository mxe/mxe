Contains ad hoc patches for cross building.

From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Marco <marco@example.com>
Date: Fri, 5 Jun 2026 20:59:00 +0200
Subject: [PATCH] CEGUI 0.8.7 fixes

1. Separate shared and static builds
2. Remove unsupported cmake_policy OLD calls
3. Fix libxml2 compile error with modern libxml2
4. Enable pkg-config generation for Windows

diff -ur cegui-0-8-7/cegui/src/XMLParserModules/Libxml2/XMLParser.cpp cegui-0-8-7-new/cegui/src/XMLParserModules/Libxml2/XMLParser.cpp
--- cegui-0-8-7/cegui/src/XMLParserModules/Libxml2/XMLParser.cpp	2016-04-28 21:53:04.000000000 +0200
+++ cegui-0-8-7-new/cegui/src/XMLParserModules/Libxml2/XMLParser.cpp	2026-06-05 20:58:04.145178585 +0200
@@ -99,7 +99,7 @@
 
     if (!doc)
     {
-        xmlError* err = xmlGetLastError();
+        const xmlError* err = xmlGetLastError();
 
         CEGUI_THROW(GenericException(
             String("xmlParseMemory failed in file: '") +
diff -ur cegui-0-8-7/cmake/CEGUIMacros.cmake cegui-0-8-7-new/cmake/CEGUIMacros.cmake
--- cegui-0-8-7/cmake/CEGUIMacros.cmake	2026-06-05 20:39:44.028743947 +0200
+++ cegui-0-8-7-new/cmake/CEGUIMacros.cmake	2026-06-05 20:48:02.911440880 +0200
@@ -53,7 +53,11 @@
         target_link_libraries(${_TARGET_NAME} ${ARGN})
     endif()
 
-    get_target_property(_TARGET_EXISTS ${_TARGET_NAME}_Static TYPE)
+    if (TARGET ${_TARGET_NAME}_Static)
+        set(_TARGET_EXISTS TRUE)
+    else()
+        set(_TARGET_EXISTS FALSE)
+    endif()
     if (_TARGET_EXISTS)
         foreach(_LIB ${ARGN})
             if (${_LIB} STREQUAL optimized OR ${_LIB} STREQUAL debug OR ${_LIB} STREQUAL general)
@@ -75,7 +79,11 @@
 # add dynamic dependency libraries to a target
 #
 macro (cegui_add_dependency_dynamic_libs _TARGET_NAME _DEP_NAME)
-    get_target_property(_TARGET_EXISTS ${_TARGET_NAME} TYPE)
+    if (TARGET ${_TARGET_NAME})
+        set(_TARGET_EXISTS TRUE)
+    else()
+        set(_TARGET_EXISTS FALSE)
+    endif()
 
     if (_TARGET_EXISTS)
         if (${_DEP_NAME}_LIBRARIES)
@@ -100,7 +108,11 @@
 # if static do not exist)
 #
 macro (cegui_add_dependency_static_libs _TARGET_NAME _DEP_NAME)
-    get_target_property(_TARGET_EXISTS ${_TARGET_NAME} TYPE)
+    if (TARGET ${_TARGET_NAME})
+        set(_TARGET_EXISTS TRUE)
+    else()
+        set(_TARGET_EXISTS FALSE)
+    endif()
 
     if (_TARGET_EXISTS)
         if (${_DEP_NAME}_LIBRARIES_STATIC)
@@ -139,8 +151,16 @@
 #
 macro (cegui_add_dependency _TARGET_NAME _DEP_NAME)
 # Optional additional arguments: "SCOPE" "IS_SYSTEM"
-    get_target_property(_DYNAMIC_EXISTS ${_TARGET_NAME} TYPE)
-    get_target_property(_STATIC_EXISTS ${_TARGET_NAME}_Static TYPE)
+    if (TARGET ${_TARGET_NAME})
+        set(_DYNAMIC_EXISTS TRUE)
+    else()
+        set(_DYNAMIC_EXISTS FALSE)
+    endif()
+    if (TARGET ${_TARGET_NAME}_Static)
+        set(_STATIC_EXISTS TRUE)
+    else()
+        set(_STATIC_EXISTS FALSE)
+    endif()
     if ("${ARGC}" GREATER 2)
         if (("${ARGC}" GREATER 3) AND "${ARGV3}")
             if (_DYNAMIC_EXISTS)
@@ -169,8 +189,10 @@
     ###########################################################################
     #                    NON-STATIC VERSION OF TARGET
     ###########################################################################
-    if (${_DEP_NAME}_DEFINITIONS)
-        set_property( TARGET ${_TARGET_NAME} APPEND PROPERTY COMPILE_DEFINITIONS ${${_DEP_NAME}_DEFINITIONS} )
+    if (CEGUI_BUILD_SHARED_CONFIGURATION)
+        if (${_DEP_NAME}_DEFINITIONS)
+            set_property( TARGET ${_TARGET_NAME} APPEND PROPERTY COMPILE_DEFINITIONS ${${_DEP_NAME}_DEFINITIONS} )
+        endif()
     endif()
 
     if (CEGUI_BUILD_SHARED_LIBS_WITH_STATIC_DEPENDENCIES)
@@ -303,11 +325,13 @@
             set(_CEGUI_LIB_DEST ${CEGUI_LIB_INSTALL_DIR})
         endif()
 
-        install(TARGETS ${_LIB_NAME}
-            RUNTIME DESTINATION bin
-            LIBRARY DESTINATION ${_CEGUI_LIB_DEST}
-            ARCHIVE DESTINATION ${CEGUI_LIB_INSTALL_DIR}
-        )
+        if (CEGUI_BUILD_SHARED_CONFIGURATION)
+            install(TARGETS ${_LIB_NAME}
+                RUNTIME DESTINATION bin
+                LIBRARY DESTINATION ${_CEGUI_LIB_DEST}
+                ARCHIVE DESTINATION ${CEGUI_LIB_INSTALL_DIR}
+            )
+        endif()
 
         if (CEGUI_BUILD_STATIC_CONFIGURATION)
             install(TARGETS ${_LIB_NAME}_Static
diff -ur cegui-0-8-7/CMakeLists.txt cegui-0-8-7-new/CMakeLists.txt
--- cegui-0-8-7/CMakeLists.txt	2016-04-28 21:53:04.000000000 +0200
+++ cegui-0-8-7-new/CMakeLists.txt	2026-06-05 20:59:05.649823993 +0200
@@ -3,11 +3,11 @@
 ################################################################################
 cmake_minimum_required(VERSION 2.8.11)
 if (POLICY CMP0017)
-    cmake_policy(SET CMP0017 OLD)
+    cmake_policy(SET CMP0017 NEW)
 endif()
 
 if (POLICY CMP0045)
-    cmake_policy(SET CMP0045 OLD)
+    cmake_policy(SET CMP0045 NEW)
 endif()
 
 if (APPLE AND NOT CMAKE_OSX_ARCHITECTURES)
@@ -599,7 +599,7 @@
 configure_file( samples/common/include/CEGUISamplesConfig.h.in samples/common/include/CEGUISamplesConfig.h )
 configure_file( doc/doxygen/doxyfile.in doc/doxygen/doxyfile )
 
-if (UNIX AND NOT APPLE)
+if (CEGUI_INSTALL_PKGCONFIG)
     configure_file( cegui/CEGUI.pc.in cegui/CEGUI-${CEGUI_VERSION_MAJOR}.pc @ONLY )
     install(FILES ${PROJECT_BINARY_DIR}/cegui/CEGUI-${CEGUI_VERSION_MAJOR}.pc DESTINATION ${CEGUI_PKGCONFIG_INSTALL_DIR})
 

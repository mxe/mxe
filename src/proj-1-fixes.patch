From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Mark Brand <mabrand@mabrand.nl>
Date: Sun, 31 May 2026 12:13:37 +0200
Subject: [PATCH 1/2] fix output name for mingw


diff --git a/src/lib_proj.cmake b/src/lib_proj.cmake
index 1111111..2222222 100644
--- a/src/lib_proj.cmake
+++ b/src/lib_proj.cmake
@@ -517,7 +517,7 @@ target_include_directories(proj INTERFACE
   $<BUILD_INTERFACE:${PROJ_SOURCE_DIR}/include>
   $<INSTALL_INTERFACE:${CMAKE_INSTALL_INCLUDEDIR}>)
 
-if(WIN32)
+if(WIN32 AND NOT MINGW)
     if (MINGW AND BUILD_SHARED_LIBS)
         option(APPEND_SOVERSION "Whether to include shared object version as a suffix in the name of the PROJ shared library name." OFF)
     endif()

From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Mark Brand <mabrand@mabrand.nl>
Date: Sun, 31 May 2026 13:13:16 +0200
Subject: [PATCH 2/2] MXE hack: fix curl deps


diff --git a/src/lib_proj.cmake b/src/lib_proj.cmake
index 1111111..2222222 100644
--- a/src/lib_proj.cmake
+++ b/src/lib_proj.cmake
@@ -608,14 +608,9 @@ endif()
 
 if(CURL_ENABLED)
   target_compile_definitions(proj PRIVATE -DCURL_ENABLED)
-  target_link_libraries(proj PRIVATE CURL::libcurl)
-  target_link_libraries(proj
-    PRIVATE
-      $<$<CXX_COMPILER_ID:MSVC>:ws2_32>
-      $<$<CXX_COMPILER_ID:MSVC>:wldap32>
-      $<$<CXX_COMPILER_ID:MSVC>:advapi32>
-      $<$<CXX_COMPILER_ID:MSVC>:crypt32>
-      $<$<CXX_COMPILER_ID:MSVC>:normaliz>)
+  set(MXE_CURL_LIBS "" CACHE STRING "mxe curl libs")
+  print_variable(MXE_CURL_LIBS)
+  target_link_libraries(proj PRIVATE ${MXE_CURL_LIBS})
 endif()
 
 if(EMSCRIPTEN_FETCH_ENABLED)
